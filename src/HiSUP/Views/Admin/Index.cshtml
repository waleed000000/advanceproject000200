@model HiSUP.Models.DashboardStats
@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .dash-card {
        border-radius: 20px;
        padding: 30px;
        color: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        transition: all 0.3s;
        position: relative;
        overflow: hidden;
    }
    .dash-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }
    .dash-card::before {
        content: '';
        position: absolute;
        top: -50%; right: -20%;
        width: 150px; height: 150px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
    }
    .dash-card .icon { font-size: 3rem; opacity: 0.8; }
    .dash-card .number { font-size: 3rem; font-weight: 900; }
    .dash-card .label { font-size: 1rem; opacity: 0.9; }
    .card-blue { background: linear-gradient(135deg, #667eea, #764ba2); }
    .card-green { background: linear-gradient(135deg, #11998e, #38ef7d); }
    .card-orange { background: linear-gradient(135deg, #f7971e, #ffd200); }
    .card-red { background: linear-gradient(135deg, #f953c6, #b91d73); }
    .card-teal { background: linear-gradient(135deg, #4facfe, #00f2fe); }
    .card-dark { background: linear-gradient(135deg, #434343, #000000); }
    .action-btn {
        border-radius: 12px;
        padding: 12px 20px;
        font-weight: 600;
        transition: all 0.3s;
        border: none;
        margin: 5px;
    }
    .action-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.2); }
    .dashboard-header {
        background: linear-gradient(135deg, #667eea, #764ba2);
        border-radius: 20px;
        padding: 30px;
        color: white;
        margin-bottom: 30px;
    }
</style>

<!-- Dashboard Header -->
<div class="dashboard-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 style="color:white; font-weight:900;">🛡️ Admin Dashboard</h2>
            <p style="color:rgba(255,255,255,0.8); margin:0;">Welcome, @User.Identity?.Name</p>
        </div>
        <div style="font-size:4rem;">🎓</div>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-4 col-6">
        <div class="dash-card card-blue">
            <div class="icon">👨‍🎓</div>
            <div class="number">@Model.TotalStudents</div>
            <div class="label">Total Students</div>
        </div>
    </div>
    <div class="col-md-4 col-6">
        <div class="dash-card card-green">
            <div class="icon">👨‍🏫</div>
            <div class="number">@Model.TotalFaculty</div>
            <div class="label">Total Faculty</div>
        </div>
    </div>
    <div class="col-md-4 col-6">
        <div class="dash-card card-orange">
            <div class="icon">📘</div>
            <div class="number">@Model.TotalCourses</div>
            <div class="label">Total Courses</div>
        </div>
    </div>
    <div class="col-md-4 col-6">
        <div class="dash-card card-red">
            <div class="icon">🏛️</div>
            <div class="number">@Model.TotalDepartments</div>
            <div class="label">Departments</div>
        </div>
    </div>
    <div class="col-md-4 col-6">
        <div class="dash-card card-teal">
            <div class="icon">📚</div>
            <div class="number">@Model.TotalLibraryItems</div>
            <div class="label">Library Items</div>
        </div>
    </div>
    <div class="col-md-4 col-6">
        <div class="dash-card card-dark">
            <div class="icon">💰</div>
            <div class="number">@Model.TotalFeeCollected.ToString("N0")</div>
            <div class="label">Fee Collected (Rs.)</div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="card" style="border-radius:20px; border:none; box-shadow: 0 5px 20px rgba(0,0,0,0.1);">
    <div class="card-body p-4">
        <h5 style="color:#333; font-weight:700; margin-bottom:20px;">⚡ Quick Actions</h5>
        <a href="/Student" class="btn action-btn btn-primary">👨‍🎓 Students</a>
        <a href="/Faculty" class="btn action-btn btn-success">👨‍🏫 Faculty</a>
        <a href="/Course" class="btn action-btn btn-warning">📘 Courses</a>
        <a href="/Library" class="btn action-btn btn-info">📚 Library</a>
        <a href="/Fee" class="btn action-btn btn-danger">💰 Fees</a>
    </div>
</div>