@model List<HiSUP.Models.FeePayment>
@{ ViewData["Title"] = "Fee Payments"; }

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>💰 Fee Payments</h2>
        <a asp-action="Create" class="btn btn-primary">+ Record Payment</a>
    </div>
    <div class="card shadow">
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr><th>ID</th><th>Student</th><th>Amount</th><th>Method</th><th>Date</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.PaymentID</td>
                            <td>@p.StudentName</td>
                            <td>Rs. @p.Amount</td>
                            <td>@p.PaymentMethod</td>
                            <td>@p.PaymentDate.ToShortDateString()</td>
                            <td><span class="badge bg-success">@p.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>