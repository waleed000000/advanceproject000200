@model HiSUP.Models.Course
@{ ViewData["Title"] = "Add Course"; }

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white"><h4>📘 Add New Course</h4></div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="CourseName" class="form-label"></label>
                            <input asp-for="CourseName" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="CourseCode" class="form-label"></label>
                            <input asp-for="CourseCode" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="CreditHours" class="form-label"></label>
                            <input asp-for="CreditHours" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="DepartmentID" class="form-label"></label>
                            <input asp-for="DepartmentID" class="form-control" />
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Add Course</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>