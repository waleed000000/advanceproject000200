@model List<HiSUP.Models.Faculty>
@{ViewData["Title"] = "Faculty";}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>👨‍🏫 All Faculty</h2>
        <a asp-action="Create" class="btn btn-primary">+ Add Faculty</a>
    </div>
    <div class="card shadow">
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Designation</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in Model)
                    {
                        <tr>
                            <td>@f.FacultyID</td>
                            <td>@f.FirstName @f.LastName</td>
                            <td>@f.Email</td>
                            <td>@f.Designation</td>
                            <td>
                                <span class="badge @(f.Status == "Active" ? "bg-success" : "bg-danger")">
                                    @f.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>